# Public site URL for metadata / OG / sitemap (https://..., no trailing slash).
# Override with your real domain; code fallback is humasalon.com.pk if unset.
NEXT_PUBLIC_SITE_URL=https://humasalon.com.pk

# Admin: omit ADMIN_PASSWORD for local dev (default login: admin123).
# In production set ADMIN_PASSWORD=... and ADMIN_SESSION_SECRET=... (no spaces around =).
ADMIN_SESSION_SECRET=random-long-secret-string

# Appointments are stored on disk under ./data/ (bookings.json + appointments-log.jsonl).
# Serverless hosts (e.g. Vercel) cannot persist this; use a DB or always run on your own server/PC.

# Production checklist:
# - Set ADMIN_PASSWORD and ADMIN_SESSION_SECRET (long random strings; never commit .env.local).
# - Set NEXT_PUBLIC_SITE_URL to your live origin (https://...) for OG, sitemap, and JSON-LD.
# - Prefer HTTPS so the admin session cookie can use the Secure flag.
